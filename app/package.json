{
  "name": "@dnd/app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:seed:real-campaign": "tsx src/server/db/seed-real-campaign.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:check": "drizzle-kit check --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "@dnd/library": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "drizzle-orm": "1.0.0-beta.2-f9236e3",
    "nitro": "npm:nitro-nightly@3.0.1-20260212-205859-0f4c665f",
    "postgres": "^3.4.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "vite-tsconfig-paths": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.3.1",
    "drizzle-kit": "1.0.0-beta.2-f9236e3",
    "tsx": "^4.21.0",
    "typescript": "^5.7",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}

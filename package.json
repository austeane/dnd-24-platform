{
  "name": "dnd-24-platform",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm -F @dnd/app build",
    "start": "node app/.output/server/index.mjs",
    "compile": "tsx scripts/compile-canon.ts",
    "import:srd-spells": "tsx scripts/import-srd-spells.ts",
    "check": "pnpm -r run check",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "pnpm -r run test",
    "test:integration": "pnpm -F @dnd/app test:integration",
    "extract:character-sheets": "tsx scripts/extract-character-sheets.ts",
    "seed:real-campaign": "pnpm -F @dnd/app db:seed:real-campaign",
    "db:generate": "pnpm -F @dnd/app db:generate",
    "db:migrate": "pnpm -F @dnd/app db:migrate",
    "db:push": "pnpm -F @dnd/app db:push",
    "db:check": "pnpm -F @dnd/app db:check",
    "db:studio": "pnpm -F @dnd/app db:studio",
    "db:test:up": "tsx scripts/test-db.ts up",
    "db:test:env": "tsx scripts/test-db.ts env",
    "db:test:status": "tsx scripts/test-db.ts status",
    "db:test:down": "tsx scripts/test-db.ts down",
    "report:mechanics-coverage": "tsx scripts/report-mechanics-coverage.ts",
    "report:fleet-readiness": "tsx scripts/report-fleet-readiness.ts",
    "snapshot:live-roster": "tsx scripts/snapshot-live-roster.ts",
    "snapshot:fixture-roster": "tsx scripts/snapshot-fixture-roster.ts",
    "snapshot:tavern-session": "tsx scripts/snapshot-tavern-session.ts",
    "seed:tavern-session": "tsx scripts/seed-tavern-session.ts",
    "test:acceptance:tavern": "playwright test -c playwright.tavern.config.ts",
    "test:accessibility:tavern": "tsx scripts/test-tavern-accessibility.ts",
    "verify:railway:tavern": "tsx scripts/verify-railway-tavern-smoke.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "husky": "^9",
    "lighthouse": "^13.0.3",
    "lint-staged": "^15",
    "oxlint": "^0.16",
    "tsx": "^4.21.0",
    "typescript": "^5.7",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint"
    ]
  }
}
